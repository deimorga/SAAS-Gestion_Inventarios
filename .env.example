# Copiar a .env y ajustar valores

# Base de datos
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=inventory_db

# Redis (solo en producción)
REDIS_PASSWORD=change-me-redis-password

# JWT
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32

# Dominio del API (producción)
API_DOMAIN=api.inventarios.micronuba.com

# Swagger / ReDoc — desactivar en producción
ENABLE_SWAGGER=false

# ── Admin bootstrap ────────────────────────────────────────────────────────
# Protege POST /admin/auth/register. Dejar vacío una vez creado el primer super_admin.
# Generar con: openssl rand -hex-32
ADMIN_BOOTSTRAP_SECRET=change-me-bootstrap-secret

# ── Email — Resend ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@micronuba.com
RESEND_FROM_NAME=MicroNuba

# ── Activación de usuarios ─────────────────────────────────────────────────
# URL base para enlaces de activación en emails
# Dev: http://api.inventarios.local:8090  |  Prod: https://portal.micronuba.com
ACTIVATION_BASE_URL=http://api.inventarios.local:8090
ACTIVATION_TOKEN_TTL_HOURS=48

# ── API Keys ───────────────────────────────────────────────────────────────
API_KEY_EXPIRY_DAYS=365
API_KEY_ROTATION_GRACE_DAYS=30
